# PostgreSQL
POSTGRES_USER=football_user
POSTGRES_PASSWORD=football_pass
POSTGRES_DB=football_db

# pgAdmin
PGADMIN_EMAIL=admin@football.local
PGADMIN_PASSWORD=pgadmin_pass

# Airflow
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# Apache NiFi (password must be >= 12 characters)
NIFI_USER=nifi_admin
NIFI_PASSWORD=nifi_admin12345

# Elasticsearch / Kibana
ES_INDEX=football_events
